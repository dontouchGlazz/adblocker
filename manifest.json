{
    "manifest_version": 3,
    "name": "epic skibidi adblocker",
    "version": "1.0",
    "description": "i am on my last straw",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "webRequest", 
        "webRequestBlocking", 
        "declarativeNetRequest",
        "activeTab"
    ],
    
    "host_permission": ["<all_urls>"],
    
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}